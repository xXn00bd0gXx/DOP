# Clean exits restoring cursor visibility safely
function Exit-Demo {
    if ($hasConsole) {
        try { [Console]::CursorVisible = $initialCursorState } catch {}
    }
    Clear-Host
    Write-Host "Demo Terminated. Thanks for exploring the depths!" -ForegroundColor Green
    exit
}

# Dynamic sliding-door and collision handler
function Test-Walkable {
    param([int]$tx, [int]$ty)
    if ($tx -lt 0 -or $tx -ge $mapWidth -or $ty -lt 0 -or $ty -ge $mapHeight) {
        return $false
    }
    $cell = $flatMap[$ty * $mapWidth + $tx]
    if ($cell -eq 0) {
        return $true
    }
    if ($cell -eq 2) {
        $doorKey = "$tx,$ty"
        if ($doorStates.ContainsKey($doorKey)) {
            if ($doorStates[$doorKey].Ratio -ge 0.8) {
                return $true # Door is open
            }
        }
    }
    return $false
}

# --- MAIN ENGINE LOOP ---
$running = $true
$clock = [System.Diagnostics.Stopwatch]::StartNew()
$lastTime = $clock.ElapsedMilliseconds

while ($running) {
    # 1. TIMING & ENGINE REGULATION
    $currentTime = $clock.ElapsedMilliseconds
    $elapsed = $currentTime - $lastTime

    # Target exactly 10 FPS (100ms per frame) for steady, smooth execution
    if ($elapsed -lt 100) {
        Start-Sleep -Milliseconds 5
        continue
    }
    $lastTime = $currentTime
    $fps = [int](1000 / $elapsed)

    # Calculate real-time flickering factor for dungeon torches
    $flicker = 1.0 + [math]::Sin($currentTime / 180.0) * 0.08 + ( (Get-Random -Min 0 -Max 100) / 1000.0 - 0.05 )

    # Tick animated doors open or closed
    foreach ($key in $doorStates.Keys) {
        $door = $doorStates[$key]
        if ($door.State -eq "Opening") {
            $door.Ratio += 0.2
            if ($door.Ratio -ge 1.0) {
                $door.Ratio = 1.0
                $door.State = "Open"
            }
        } elseif ($door.State -eq "Closing") {
            # ANTI-STUCK PROTECTOR: Force door back open if player is standing on it!
            $coords = $key -split ","
            $doorX = [int]$coords[0]
            $doorY = [int]$coords[1]
            $pDistToDoorCenter = [math]::Sqrt(($doorX + 0.5 - $px)*($doorX + 0.5 - $px) + ($doorY + 0.5 - $py)*($doorY + 0.5 - $py))
            if ($pDistToDoorCenter -lt 0.7) {
                $door.State = "Opening"
            } else {
                $door.Ratio -= 0.2
                if ($door.Ratio -le 0.0) {
                    $door.Ratio = 0.0
                    $door.State = "Closed"
                }
            }
        }
    }

    # Detect if player is near any interactive sliding door (within smaller 1.1 units radius)
    $nearDoor = $false
    $nearDoorX = 0
    $nearDoorY = 0
    for ($dy = -1; $dy -le 1; $dy++) {
        for ($dx = -1; $dx -le 1; $dx++) {
            $tx = [int][math]::Floor($px) + $dx
            $ty = [int][math]::Floor($py) + $dy
            if ($tx -ge 0 -and $tx -lt $mapWidth -and $ty -ge 0 -and $ty -lt $mapHeight) {
                if ($flatMap[$ty * $mapWidth + $tx] -eq 2) {
                    $distToDoor = [math]::Sqrt(($tx + 0.5 - $px)*($tx + 0.5 - $px) + ($ty + 0.5 - $py)*($ty + 0.5 - $py))
                    if ($distToDoor -lt 1.1) { # Reduced interaction radius
                        $nearDoor = $true
                        $nearDoorX = $tx
                        $nearDoorY = $ty
                    }
                }
            }
        }
    }

    # 2. KEYBOARD INPUT (Non-blocking, Redirection-Safe)
    $keyAvailable = $false
    if ($canUseConsole) {
        try {
            if ([Console]::KeyAvailable) { $keyAvailable = $true }
        } catch {
            $canUseConsole = $false
        }
    }
    if (-not $keyAvailable) {
        try {
            if ($Host.UI.RawUI.KeyAvailable) { $keyAvailable = $true }
        } catch {}
    }

    if ($keyAvailable) {
        $keyChar = ""
        if ($canUseConsole) {
            try {
                $keyChar = [Console]::ReadKey($true).Key.ToString()
            } catch {}
        } else {
            try {
                $rawKey = $Host.UI.RawUI.ReadKey("NoEcho,IncludeKeyDown").VirtualKeyCode
                $keyChar = switch($rawKey) {
                    38 { "W" }
                    40 { "S" }
                    37 { "A" }
                    39 { "D" }
                    27 { "Escape" }
                    default { [char]$rawKey }
                }
            } catch {}
        }

        # Optimized movement: Slowed down by 20% from original spec to increase accuracy and precision
        $moveStep = 0.2133 
        $rotStep  = 0.1257  # Snappy, increased by 15% from 0.1093

        switch ($keyChar) {
            "W" {
                $nx = $px + [math]::Cos($pa) * $moveStep
                $ny = $py + [math]::Sin($pa) * $moveStep

                # Sliding collision detection with standard 0.25 player radius
                $radius = 0.25
                $offsetEndX = $radius
                if ($nx -le $px) { $offsetEndX = -$radius }
                $offsetEndY = $radius
                if ($ny -le $py) { $offsetEndY = -$radius }

                $checkX = $nx + $offsetEndX
                $checkY = $ny + $offsetEndY

                $intCheckX = [int][math]::Floor($checkX)
                $intPy = [int][math]::Floor($py)
                $intCheckY = [int][math]::Floor($checkY)
                $intPx = [int][math]::Floor($px)

                if (Test-Walkable -tx $intCheckX -ty $intPy) {
                    $px = $nx
                }
                if (Test-Walkable -tx $intPx -ty $intCheckY) {
                    $py = $ny
                }
            }
            "S" {
                $nx = $px - [math]::Cos($pa) * $moveStep
                $ny = $py - [math]::Sin($pa) * $moveStep

                $radius = 0.25
                $offsetEndX = -$radius
                if ($nx -le $px) { $offsetEndX = $radius }
                $offsetEndY = -$radius
                if ($ny -le $py) { $offsetEndY = $radius }

                $checkX = $nx + $offsetEndX
                $checkY = $ny + $offsetEndY

                $intCheckX = [int][math]::Floor($checkX)
                $intPy = [int][math]::Floor($py)
                $intCheckY = [int][math]::Floor($checkY)
                $intPx = [int][math]::Floor($px)

                if (Test-Walkable -tx $intCheckX -ty $intPy) {
                    $px = $nx
                }
                if (Test-Walkable -tx $intPx -ty $intCheckY) {
                    $py = $ny
                }
            }
            "A" {
                $pa -= $rotStep
                if ($pa -lt 0) { $pa += [math]::PI * 2 }
            }
            "D" {
                $pa += $rotStep
                if ($pa -gt [math]::PI * 2) { $pa -= [math]::PI * 2 }
            }
            "E" {
                if ($nearDoor) {
                    $doorKey = "$nearDoorX,$nearDoorY"
                    if ($doorStates.ContainsKey($doorKey)) {
                        $dState = $doorStates[$doorKey]
                        if ($dState.State -eq "Closed" -or $dState.State -eq "Closing") {
                            $dState.State = "Opening"
                        } else {
                            $dState.State = "Closing"
                        }
                    }
                }
            }
            "Escape" {
                $running = $false
            }
        }

        # DRAIN INPUT BUFFER: Prevents sliding or runaway camera spins
        if ($canUseConsole) {
            while ($true) {
                $avail = $false
                try { if ([Console]::KeyAvailable) { $avail = $true } } catch {}
                if (-not $avail) { break }
                try { [Console]::ReadKey($true) | Out-Null } catch {}
            }
        } else {
            while ($true) {
                $avail = $false
                try { if ($Host.UI.RawUI.KeyAvailable) { $avail = $true } } catch {}
                if (-not $avail) { break }
                try { [void]$Host.UI.RawUI.ReadKey("NoEcho,IncludeKeyDown") } catch {}
            }
        }
    }

    # 3. GAME ENVIRONMENT CONTROLLERS
    # Re-calculate sprite depths
    foreach ($s in $sprites) {
        $s.Dist = [math]::Sqrt(($s.X - $px) * ($s.X - $px) + ($s.Y - $py) * ($s.Y - $py))
    }

    # Skeleton proximity damage on crypt floor
    $skelDist = $sprites[0].Dist
    if ($skelDist -lt 1.3 -and $hp -gt 0) {
        $hp = [math]::Max($hp - 4, 0)
    } elseif ($hp -lt $maxHp -and (Get-Random -Max 10) -lt 1) {
        $hp = [math]::Min($hp + 1, $maxHp)
    }

    # 4. ENGINE RENDERING (Double-Buffered Frame Builder)
    $buffer.Clear() | Out-Null

    # Re-position cursor safely
    if ($hasConsole) {
        try {
            [Console]::SetCursorPosition(0, 0)
        } catch {
            [void]$buffer.Append("$esc[H")
        }
    } else {
        [void]$buffer.Append("$esc[H")
    }

    $sinPA = [math]::Sin($pa)
    $cosPA = [math]::Cos($pa)

    # --- DDA WALL CASTING LOOP ---
    for ($col = 0; $col -lt $screenWidth; $col++) {
        $cosOff = $cosOffsets[$col]
        $sinOff = $sinOffsets[$col]

        $sinA = $sinPA * $cosOff + $cosPA * $sinOff
        $cosA = $cosPA * $cosOff - $sinPA * $sinOff

        $deltaDistX = 1e30
        if ($cosA -ne 0) { $deltaDistX = [math]::Abs(1 / $cosA) }

        $deltaDistY = 1e30
        if ($sinA -ne 0) { $deltaDistY = [math]::Abs(1 / $sinA) }

        $mapX = [int][math]::Floor($px)
        $mapY = [int][math]::Floor($py)

        $sideDistX = 0.0
        $sideDistY = 0.0
        $stepX = 0
        $stepY = 0

        if ($cosA -lt 0) {
            $stepX = -1
            $sideDistX = ($px - $mapX) * $deltaDistX
        } else {
            $stepX = 1
            $sideDistX = (($mapX + 1.0) - $px) * $deltaDistX
        }

        if ($sinA -lt 0) {
            $stepY = -1
            $sideDistY = ($py - $mapY) * $deltaDistY
        } else {
            $stepY = 1
            $sideDistY = (($mapY + 1.0) - $py) * $deltaDistY
        }

        $hit = $false
        $side = 0 
        $maxDepth = 24.0 
        $dist = 0.0
        $hitCellType = 0 # 1=Wall, 2=Door

        while (-not $hit) {
            if ($sideDistX -lt $sideDistY) {
                $sideDistX += $deltaDistX
                $mapX += $stepX
                $side = 0
            } else {
                $sideDistY += $deltaDistY
                $mapY += $stepY
                $side = 1
            }

            if ($mapX -lt 0 -or $mapX -ge $mapWidth -or $mapY -lt 0 -or $mapY -ge $mapHeight) {
                $dist = $maxDepth
                break
            }

            $cellVal = $flatMap[$mapY * $mapWidth + $mapX]
            if ($cellVal -eq 1 -or $cellVal -eq 2) {
                if ($cellVal -eq 2) {
                    # --- HORIZONTAL SLIDING DOOR MECHANISM ---
                    $doorKey = "$mapX,$mapY"
                    $ratio = 0.0
                    if ($doorStates.ContainsKey($doorKey)) {
                        $ratio = $doorStates[$doorKey].Ratio
                    }

                    if ($ratio -lt 1.0) {
                        # Determine intersection offset along the door panel
                        if ($side -eq 0) {
                            $wallX = $py + ($sideDistX - $deltaDistX) * $sinA
                        } else {
                            $wallX = $px + ($sideDistY - $deltaDistY) * $cosA
                        }
                        $wallX = $wallX % 1.0

                        # If the ray hits the closed part of the sliding door
                        if ($wallX -ge $ratio) {
                            $hit = $true
                            $hitCellType = 2
                            if ($side -eq 0) { $dist = $sideDistX - $deltaDistX } else { $dist = $sideDistY - $deltaDistY }
                        }
                    }
                } else {
                    # Solid Wall Hit
                    $hit = $true
                    $hitCellType = 1
                    if ($side -eq 0) { $dist = $sideDistX - $deltaDistX } else { $dist = $sideDistY - $deltaDistY }
                }
            }
        }

        # Fish-eye angle offset subtraction
        $dist *= $cosOff
        if ($dist -lt 0.1) { $dist = 0.1 }

        $zBuffer[$col] = $dist

        # Compute wall coordinate projections
        $wallHeight = [int]($virtualHeight / $dist)
        $wallStart  = [int](($virtualHeight - $wallHeight) / 2)
        $wallEnd    = $wallStart + $wallHeight

        if ($wallStart -lt 0) { $wallStart = 0 }
        if ($wallEnd -ge $virtualHeight) { $wallEnd = $virtualHeight - 1 }

        if ($side -eq 0) { $wallX = $py + $dist * $sinA } else { $wallX = $px + $dist * $cosA }
        $wallX = $wallX % 1.0

        $texX = [int]($wallX * 32)
        if ($texX -lt 0) { $texX = 0 }
        if ($texX -gt 31) { $texX = 31 }

        $hasTorch = (($mapX + $mapY) % 2 -eq 0 -and $hitCellType -eq 1)

        $isBottomHalf = $false
        $frameIdx = $col

        # Render slice column
        for ($y = 0; $y -lt $virtualHeight; $y++) {
            $pixelColor = 232

            if ($y -ge $wallStart -and $y -le $wallEnd) {
                $wallHeightVal = ($wallEnd - $wallStart)
                if ($wallHeightVal -le 0) { $wallHeightVal = 1 }
                $texY = [int]((($y - $wallStart) / $wallHeightVal) * 16)
                if ($texY -lt 0) { $texY = 0 }
                if ($texY -gt 15) { $texY = 15 }

                if ($hitCellType -eq 2) {
                    # --- STONE FLANKED WOODEN PLANK DOOR TEXTURE ---
                    # Columns 0-7 (Left 25%) and Columns 24-31 (Right 25%) are solid stone bricks.
                    # Columns 8-23 (Middle 50%) is the actual wooden door.
                    if ($texX -lt 8 -or $texX -ge 24) {
                        # Solid stone flank
                        $brickRow = [math]::Floor($texY / 8)
                        $isMortarY = ($texY % 8 -eq 0)
                        $isMortarX = ($brickRow % 2 -eq 0 -and ($texX -eq 0 -or $texX -eq 16)) -or ($brickRow % 2 -eq 1 -and ($texX -eq 8 -or $texX -eq 24))
                        $isMortar = $isMortarY -or $isMortarX
                        if ($isMortar) {
                            $pixelColor = 235 # Dark mortar
                        } else {
                            $pixelColor = 244 # Slate grey stone
                        }
                    } else {
                        # Wooden door panel
                        if ($texY -le 1 -or $texY -ge 14) {
                            $pixelColor = 237 # Iron strap plates
                        } elseif ($texX -eq 8 -or $texX -eq 16 -or $texX -eq 23) {
                            $pixelColor = 233 # Plank gaps
                        } elseif ($texX -ge 14 -and $texX -le 17 -and $texY -ge 7 -and $texY -le 9) {
                            # Gold door pull handle in center of panel
                            if ($texY -eq 8 -and $texX -ge 15 -and $texX -le 16) {
                                $pixelColor = 233 # Handle core hole
                            } else {
                                $pixelColor = 220 # Gold ring
                            }
                        } else {
                            $pixelColor = 130 # Oak timber wood paneling
                        }
                    }
                } else {
                    # --- STANDARD STONE BRICK WALLS ---
                    $brickRow = [math]::Floor($texY / 8)
                    $isMortarY = ($texY % 8 -eq 0)
                    $isMortarX = ($brickRow % 2 -eq 0 -and ($texX -eq 0 -or $texX -eq 16)) -or ($brickRow % 2 -eq 1 -and ($texX -eq 8 -or $texX -eq 24))
                    $isMortar = $isMortarY -or $isMortarX

                    if ($hasTorch -and $texX -ge 14 -and $texX -le 17 -and $texY -ge 3 -and $texY -le 7) {
                        # --- FLICKERING TORCHES ---
                        if ($texY -eq 3) {
                            $frame = [math]::Floor($currentTime / 150) % 3
                            if ($frame -eq 0) { $pixelColor = 226 }
                            elseif ($frame -eq 1) { $pixelColor = 208 }
                            else { $pixelColor = 196 }
                        } elseif ($texY -eq 4) {
                            $pixelColor = 202
                        } else {
                            $pixelColor = 238
                        }
                    } else {
                        if ($side -eq 0) {
                            if ($isMortar) { $pixelColor = 235 }
                            else {
                                if ($texX -eq 1 -or $texY -eq 1 -or $texY -eq 9) { $pixelColor = 250 }
                                elseif (($texX * $texY) % 7 -eq 0) { $pixelColor = 240 }
                                else { $pixelColor = 244 }
                            }
                        } else {
                            if ($isMortar) { $pixelColor = 235 }
                            else {
                                if (($texX + $texY) % 5 -eq 0) { $pixelColor = 238 }
                                elseif ($texX -eq 1 -or $texY -eq 1 -or $texY -eq 9) { $pixelColor = 246 }
                                else { $pixelColor = 242 }
                            }
                        }
                    }
                }

                # --- DYNAMIC WALL ILLUMINATION ---
                $lightGlow = 0
                if ($hasTorch) {
                    $verticalDist = [math]::Abs($y - $horizon) / $horizon
                    $lightGlow = [int](5.0 * (1.0 - $verticalDist) * $flicker / [math]::Sqrt($dist))
                }

                $shade = [int]$dist
                if ($hitCellType -eq 2) {
                    $shade = [int]($dist * 1.3)
                }
                $shade = [int]($shade - $lightGlow)
                if ($shade -lt 0) { $shade = 0 }

                # Apply fast wall shading subtraction inline
                if ($pixelColor -ge 232) {
                    $shadedVal = $pixelColor - $shade
                    if ($shadedVal -lt 232) { $pixelColor = 232 } else { $pixelColor = $shadedVal }
                }
            }
            # --- CEILING (Arena Style horizontal timber beams & black void) ---
            elseif ($y -lt $horizon) {
                $ceilDist = $ceilDistTable[$y]
                $realCeilDist = $ceilDist / $cosOff
                $ceilX = $px + $realCeilDist * $cosA
                $ceilY = $py + $realCeilDist * $sinA

                # Horizontal wood support beams only (thinner 0.04 thickness)
                $ceilYFrac = $ceilY % 1.5

                if ($ceilYFrac -lt 0.04) {
                    $pixelColor = 130 # Warm support wood
                } else {
                    $pixelColor = 232 # Deep dark void
                }

                $cShade = [int]($ceilDist * 1.2)
                if ($hasTorch) {
                    $cGlow = [int](3.0 * $flicker / ($realCeilDist + 0.5))
                    $cShade = [int]($cShade - $cGlow)
                }
                if ($cShade -lt 0) { $cShade = 0 }

                $maxShadeIdx = $beamShades.Length - 1
                if ($cShade -gt $maxShadeIdx) { $cShade = $maxShadeIdx }

                if ($pixelColor -eq 130) {
                    $pixelColor = $beamShades[$cShade]
                } else {
                    $pixelColor = 232
                }
            }
            # --- FLOOR (Detailed Stone Paving & Grout) ---
            else {
                $floorDist = $floorDistTable[$y]
                $realFloorDist = $floorDist / $cosOff
                $floorX = $px + $realFloorDist * $cosA
                $floorY = $py + $realFloorDist * $sinA

                $floorXFrac = $floorX % 1.0
                $floorYFrac = $floorY % 1.0

                $isGrout = ($floorXFrac -lt 0.06 -or $floorXFrac -gt 0.94) -or ($floorYFrac -lt 0.06 -or $floorYFrac -gt 0.94)

                if ($isGrout) {
                    $pixelColor = 232
                } else {
                    $tileX = [int][math]::Floor($floorX)
                    $tileY = [int][math]::Floor($floorY)
                    if (($tileX + $tileY) % 2 -eq 0) { 
                        $pixelColor = 237 # Slate Grey
                    } else {
                        $pixelColor = 234 # Dark Slate
                    }
                }

                $fShade = [int]($floorDist * 1.4)
                if ($hasTorch) {
                    $fGlow = [int](3.0 * $flicker / ($realFloorDist + 0.5))
                    $fShade = [int]($fShade - $fGlow)
                }
                if ($fShade -lt 0) { $fShade = 0 }

                $shadedVal = $pixelColor - $fShade
                if ($shadedVal -lt 232) { $pixelColor = 232 } else { $pixelColor = $shadedVal }
            }

            # Safety bounds check prevents IndexOutOfRangeException
            if ($isBottomHalf) { 
                if ($frameIdx -ge 0 -and $frameIdx -lt $bgFrame.Length) {
                    $bgFrame[$frameIdx] = [string]$pixelColor 
                }
                $frameIdx += $screenWidth
            } else { 
                if ($frameIdx -ge 0 -and $frameIdx -lt $fgFrame.Length) {
                    $fgFrame[$frameIdx] = [string]$pixelColor 
                }
            }

            $isBottomHalf = -not $isBottomHalf
        }
    }

    # --- OPTIMIZED SPRITE RENDERER (Fast Manual Insertion Sort) ---
    for ($i = 1; $i -lt $sprites.Count; $i++) {
        $key = $sprites[$i]
        $j = $i - 1
        while ($j -ge 0 -and $sprites[$j].Dist -lt $key.Dist) {
            $sprites[$j + 1] = $sprites[$j]
            $j = $j - 1
        }
        $sprites[$j + 1] = $key
    }

    foreach ($s in $sprites) {
        $spriteX = $s.X - $px
        $spriteY = $s.Y - $py

        $spriteAngle = [math]::Atan2($spriteY, $spriteX) - $pa
        while ($spriteAngle -lt -[math]::PI) { $spriteAngle += [math]::PI * 2 }
        while ($spriteAngle -gt [math]::PI) { $spriteAngle -= [math]::PI * 2 }

        $sDist = $s.Dist
        if ($sDist -lt 0.25) { continue }
        if ([math]::Cos($spriteAngle) -lt 0) { continue }

        $spriteScreenX = [int](($screenWidth / 2) * (1 + $spriteAngle / ($fov / 2)))

        $scaleX = 0.75
        if ($s.Texture -eq "Chest") { $scaleX = 0.45 }
        $scaleY = 0.75
        if ($s.Texture -eq "Chest") { $scaleY = 0.45 }

        $spriteSizeX = [int]($screenWidth / $sDist * $scaleX)
        $spriteSizeY = [int]($virtualHeight / $sDist * $scaleY)
        if ($spriteSizeX -le 0 -or $spriteSizeY -le 0) { continue }

        $floorY = [int]($virtualHeight / 2 + ($virtualHeight / (2 * $sDist)))
        $drawEndY = $floorY
        $drawStartY = $floorY - $spriteSizeY

        if ($drawStartY -lt 0) { $drawStartY = 0 }
        if ($drawEndY -ge $virtualHeight) { $drawEndY = $virtualHeight - 1 }

        $drawStartX = [int]($spriteScreenX - $spriteSizeX / 2)
        $drawEndX   = [int]($spriteScreenX + $spriteSizeX / 2)

        if ($drawStartX -lt 0) { $drawStartX = 0 }
        if ($drawEndX -ge $screenWidth) { $drawEndX = $screenWidth - 1 }

        $tex = switch ($s.Texture) {
            "Skeleton"   { $skeletonTex }
            "Wraith"     { $wraithTex }
            "Adventurer" { $adventurerTex }
            default      { $chestTex }
        }
        $texSize = 12
        $sShade = [int]($sDist * 1.5)

        for ($stripe = $drawStartX; $stripe -le $drawEndX; $stripe++) {
            if ($sDist -lt $zBuffer[$stripe]) {
                $widthVal = ($drawEndX - $drawStartX)
                if ($widthVal -le 0) { $widthVal = 1 }
                $texX = [int]((($stripe - $drawStartX) / $widthVal) * $texSize)
                if ($texX -lt 0) { $texX = 0 }
                if ($texX -ge $texSize) { $texX = $texSize - 1 }

                $startY = $drawStartY
                $startCharRow = $startY -shr 1
                $startIsBottomHalf = (($startY -band 1) -ne 0)
                $frameIdx = $startCharRow * $screenWidth + $stripe

                $isBottomHalf = $startIsBottomHalf

                for ($y = $drawStartY; $y -le $drawEndY; $y++) {
                    $heightVal = ($drawEndY - $drawStartY)
                    if ($heightVal -le 0) { $heightVal = 1 }
                    $texY = [int]((($y - $drawStartY) / $heightVal) * $texSize)
                    if ($texY -lt 0) { $texY = 0 }
                    if ($texY -ge $texSize) { $texY = $texSize - 1 }

                    $color = $tex[$texY][$texX]
                    if ($color -ne 0) {
                        # Apply fast inline sprite shading
                        if ($color -ge 232) {
                            $shadedVal = $color - $sShade
                            if ($shadedVal -lt 232) { $color = 232 } else { $color = $shadedVal }
                        }

                        # Safety bounds check prevents out-of-bounds array faults
                        if ($isBottomHalf) { 
                            if ($frameIdx -ge 0 -and $frameIdx -lt $bgFrame.Length) {
                                $bgFrame[$frameIdx] = [string]$color 
                            }
                        } else { 
                            if ($frameIdx -ge 0 -and $frameIdx -lt $fgFrame.Length) {
                                $fgFrame[$frameIdx] = [string]$color 
                            }
                        }
                    }

                    if ($isBottomHalf) {
                        $frameIdx += $screenWidth
                    }
                    $isBottomHalf = -not $isBottomHalf
                }
            }
        }
    }

    # 5. STRING ASSEMBLY & FLUSH (With Run-Length Color Compression)
    $lastFg = ""
    $lastBg = ""
    for ($charRow = 0; $charRow -lt $screenHeight; $charRow++) {
        $lineBuffer = New-Object System.Text.StringBuilder(1024)
        for ($col = 0; $col -lt $screenWidth; $col++) {
            $frameIdx = $charRow * $screenWidth + $col
            $fg = $fgFrame[$frameIdx]
            $bg = $bgFrame[$frameIdx]

            # Only append escape codes when a color actually changes (reduces write overhead by ~80%)
            if ($fg -ne $lastFg -or $bg -ne $lastBg) {
                $lastFg = $fg
                $lastBg = $bg
                [void]$lineBuffer.Append("$esc[38;5;${fg};48;5;${bg}m")
            }
            [void]$lineBuffer.Append([char]::Parse("▀")) # Safer Unicode character parse
        }
        $lastFg = ""
        $lastBg = ""
        [void]$buffer.Append($lineBuffer.ToString()).Append("$esc[0m`n")
    }

    # 6. RENDER SOLID COLORS HEALTH & MANA PROGRESS BARS
    # HP Bar Construction (Transitioning Green -> Yellow -> Red)
    $hpPct = $hp / $maxHp
    $hpBars = [int][math]::Max([int]($hpPct * 15), 0)
    if ($hpBars -gt 15) { $hpBars = 15 }
    $hpColor = "38;5;46;48;5;46" # Solid Green (Both FG & BG to render filled block)
    if ($hpPct -le 0.5) {
        if ($hpPct -le 0.25) { $hpColor = "38;5;196;48;5;196" } # Solid Red
        else { $hpColor = "38;5;226;48;5;226" } # Solid Yellow
    }
    # Direct string replication prevents math operation casting issues on Char
    $hpActiveStr = New-Object string ([char]'█', $hpBars)
    $hpInactiveStr = New-Object string ([char]'█', (15 - $hpBars))
    $hpBarStr = "$esc[${hpColor}m${hpActiveStr}$esc[38;5;236;48;5;236m${hpInactiveStr}$esc[0m"

    # MP Bar Construction (Solid Cyan)
    $mpPct = $mp / $maxMp
    $mpBars = [int][math]::Max([int]($mpPct * 15), 0)
    if ($mpBars -gt 15) { $mpBars = 15 }
    $mpActiveStr = New-Object string ([char]'█', $mpBars)
    $mpInactiveStr = New-Object string ([char]'█', (15 - $mpBars))
    $mpBarStr = "$esc[38;5;51;48;5;51m${mpActiveStr}$esc[38;5;236;48;5;236m${mpInactiveStr}$esc[0m"

    [void]$buffer.Append(" POSITION: X=$([math]::Round($px, 2)), Y=$([math]::Round($py, 2))  LEVEL: Stone Crypts (Lv 0)$esc[K`n")
    [void]$buffer.Append(" PLAYER STATUS: HP [$hpBarStr] $hp/$maxHp  |  MP [$mpBarStr] $mp/$maxMp$esc[K`n")
    [void]$buffer.Append(" RENDER ENGINE: DDA Raycaster (Optimized)  FPS: $fps  DRAW DIST: $maxDepth units$esc[K`n")
    if ($skelDist -lt 1.3) {
        [void]$buffer.Append(" $esc[1;31m[DANGER] SKELETON IS ATTACKING YOU! STEP BACK [S]!$esc[0m$esc[K`n")
    } elseif ($nearDoor) {
        [void]$buffer.Append(" $esc[1;33m[INTERACT] NEAR STONE & WOOD DOOR. PRESS [E] TO OPEN/CLOSE DOOR!$esc[0m$esc[K`n")
    } else {
        [void]$buffer.Append(" CONTROLS: [W/S] Move  [A/D] Rotate  [E] Use Door  [ESC] Exit$esc[K`n")
    }
    [void]$buffer.Append("$esc[0m")

    [Console]::Write($buffer.ToString())
}

