$horizon = [int]($virtualHeight / 2)

# --- OPTIMIZATION: CEILING & FLOOR PROJECTION LOOKUP TABLES ---
# Pre-calculating vertical projection distances removes division from inner loops
$ceilDistTable = New-Object "double[]" $horizon
for ($y = 0; $y -lt $horizon; $y++) {
    if ($horizon - $y -ne 0) {
        $ceilDistTable[$y] = $virtualHeight / (2.0 * ($horizon - $y))
    } else {
        $ceilDistTable[$y] = 999.0
    }
}

$floorDistTable = New-Object "double[]" $virtualHeight
for ($y = $horizon; $y -lt $virtualHeight; $y++) {
    if ($y - $horizon -ne 0) {
        $floorDistTable[$y] = $virtualHeight / (2.0 * ($y - $horizon))
    } else {
        $floorDistTable[$y] = 999.0
    }
}

# --- OPTIMIZATION: TRIGONOMETRIC LOOKUP TABLE ---
# Fully pre-computes ray angles and projection ratios to maximize frame performance
$angleOffsets = New-Object "double[]" $screenWidth
$cosOffsets   = New-Object "double[]" $screenWidth
$sinOffsets   = New-Object "double[]" $screenWidth

for ($col = 0; $col -lt $screenWidth; $col++) {
    $angleOffset = ($col / $screenWidth - 0.5) * $fov
    $angleOffsets[$col] = $angleOffset
    $cosOffsets[$col]   = [math]::Cos($angleOffset)
    $sinOffsets[$col]   = [math]::Sin($angleOffset)
}

