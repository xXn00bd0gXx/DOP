                            Write-C "  ║  " "DarkMagenta"
                            Write-C $iName.PadRight(32) "Magenta"
                            Write-C $iVal "Yellow"
                            $lPad = 8 - $iVal.Length
                            if($lPad -lt 0){$lPad=0}
                            Write-CL "$(' ' * $lPad)║" "DarkMagenta"
                        }
