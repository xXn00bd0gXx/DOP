                        Write-C $nameStr "Cyan"
                        Write-C "│ " "DarkGray"
                        Write-C $defStr "White"
                        Write-C "│ " "DarkGray"
                        Write-C $priceStr $affordable
                        Write-CL "│ $equipped" "Yellow"
