                    Write-Host ""

                    Write-CL "  ┌─────┬──────────────────┬────────┬─────────┐" "DarkGray"
                    Write-CL "  │  #  │ Armor            │ DEF    │ Price   │" "DarkGray"
                    Write-CL "  ├─────┼──────────────────┼────────┼─────────┤" "DarkGray"
                    for($i=0;$i -lt $slotArmor.Count;$i++){
